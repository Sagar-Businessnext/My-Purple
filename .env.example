# Copy this file to ".env" and adjust. Never commit .env.

# --- App ---
PURPLE_HOST=127.0.0.1
PURPLE_PORT=8765
PURPLE_LOG_LEVEL=INFO

# --- LLM (Ollama, local) ---
PURPLE_OLLAMA_BASE_URL=http://127.0.0.1:11434
PURPLE_LLM_MODEL=qwen2.5:14b-instruct-q4_K_M
PURPLE_EMBED_MODEL=nomic-embed-text

# --- Memory (PostgreSQL + pgvector) ---
# Create the DB first:  CREATE DATABASE purple;  then  CREATE EXTENSION vector;
PURPLE_PG_DSN=postgresql+asyncpg://purple:purple@127.0.0.1:5432/purple

# --- Speech ---
# Provider for v1 is "local" (faster-whisper + Piper). "sarvam" is the cloud backup.
PURPLE_SPEECH_PROVIDER=local
PURPLE_WHISPER_MODEL=medium          # tiny|base|small|medium|large-v3
PURPLE_WHISPER_DEVICE=cuda           # cuda|cpu
PURPLE_WHISPER_COMPUTE=float16       # float16 on GPU, int8 on CPU
PURPLE_TTS_ENGINE=kokoro             # kokoro (natural, default) | xtts (cloning, backup)
PURPLE_KOKORO_VOICE=af_bella         # warm, soft "her"-style voice
# Only needed if PURPLE_SPEECH_PROVIDER=sarvam
PURPLE_SARVAM_API_KEY=

# --- Safety / permissions ---
# Actions tagged high-risk (spending money, irreversible) always require confirmation.
PURPLE_REQUIRE_CONFIRMATION=true

# --- Wake word (voice loop) ---
PURPLE_ENABLE_WAKE=false
# Built-in word ("hey_jarvis", "alexa", ...) OR a path to your trained model.
# After training "hey purple" (see docs/wake_word.md): models/hey_purple.onnx
PURPLE_WAKE_MODEL=hey_jarvis
PURPLE_WAKE_THRESHOLD=0.5

# --- Phone bridge (Android via ADB) ---
PURPLE_ADB_PATH=adb
# Leave blank to use the only connected device; for Wi-Fi set this to the ip:port:
PURPLE_PHONE_SERIAL=
PURPLE_WIRELESS_ADDRESS=        # e.g. 192.168.1.50:5555  (then ask Purple to connect)

# --- Proactivity: morning briefing + boot greeting ---
PURPLE_ENABLE_SCHEDULER=true
PURPLE_BRIEFING_HOUR=7              # daily briefing time (24h); also catches up on boot if missed
PURPLE_BRIEFING_MINUTE=0
PURPLE_WEATHER_LOCATION=           # your city, e.g. "Pune" — enables real weather (Open-Meteo, no key)
# RSS feeds for headlines are configured in code (default: BBC World); weather just needs a city.
PURPLE_ENABLE_GREETING=true        # time-aware hello on startup (+ weather one-liner + news offer)
PURPLE_OPEN_UI_ON_START=true       # open the built-in web UI (http://127.0.0.1:8765/ui) on startup

# --- Screen-context observation (privacy: explicit consent, OFF by default) ---
# Off by default. Say "start observing" / "stop observing", or use the header toggle in the UI.
PURPLE_OBSERVE_DEFAULT=false        # start observing automatically on boot? (usually false)
PURPLE_OBSERVE_LOG_HISTORY=false    # also record each observed window title to the activity log
PURPLE_OBSERVE_AUTO_OFF_HOURS=4     # auto-stop observing after N hours (0 = never)
