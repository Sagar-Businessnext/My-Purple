# ============================================================================
# Purple — .gitignore
# Never commit: secrets, your personal data/memory, downloaded models, build output.
# ============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
build/
dist/
.eggs/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.hypothesis/

# --- Secrets & config (LOCAL ONLY — never commit) ---
.env
.env.*
!.env.example
*.local
google_credentials.json        # Google OAuth client secrets
google_token.json              # saved Google authorization token

# --- Your data / memory / models (local, private, often large) ---
data/                          # job-run state, tool-usage log, scratch
logs/                          # rotating runtime logs
models/                        # downloaded model files (Kokoro, wake word, ...)
*.onnx                         # wake-word / Kokoro model weights
*.bin                          # Kokoro voices, model blobs
voiceprints.json               # enrolled speaker embeddings (biometric — keep private)
*.sqlite
*.sqlite3
*.db
*.wav
*.mp3

# --- Frontend (React + Tauri) ---
frontend/**/node_modules/
frontend/**/dist/
frontend/**/.vite/
frontend/**/src-tauri/target/
frontend/**/src-tauri/gen/
*.tsbuildinfo
# Vite build output that the backend serves (generated by `npm run build`)
src/purple/web/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS cruft ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
